# Committed template for env/.env.local. Copy to env/.env.local (gitignored).
TEAMSFX_ENV=local
APP_NAME_SUFFIX=local

# Generated during provision (aadApp/create). Leave empty to mint a new registration.
BOT_ID=
AAD_APP_OBJECT_ID=
AAD_APP_TENANT_ID=

# Bot runtime settings.
APX_BASE_URL=https://localhost:444
CONNECTIONS=1
DEFAULT_DIRECTIVE=ok
NODE_TLS_REJECT_UNAUTHORIZED=0
