# Copy to .env and fill in.

# Local APX BotNotifications role base URL (where /v3/websockets/connect, the
# invoke endpoint and the /v3/websockets/upstream webhook all live). 444 is the
# BotNotifications port in the standard local INT config (BotFrontEnd is 443).
APX_BASE_URL=https://localhost:444

# The bot's MSA AppId. APX uses it as the socket botKey (group bot_{botKey}).
# In a DEBUG local APX build, negotiate accepts ?botKey=<this> with no auth.
BOT_KEY=

# Re-negotiate at this fraction of token lifetime (default 0.8).
RENEGOTIATE_FRACTION=0.8

# Parallel socket connections (>1 to exercise APX duplicate-reply dedup).
CONNECTIONS=1

# Default invoke behavior if the invoke carries no payload.value.directive.
# One of: ok | error | delay | drop | dupe
DEFAULT_DIRECTIVE=ok
